{
  "description": "Centralized credentials file template - DO NOT COMMIT TO GIT",
  "version": "1.0",
  "last_updated": "2025-11-23",

  "chatbot_service": {
    "deepseek_api_key": "YOUR_DEEPSEEK_API_KEY_HERE",
    "cosyvoice_api_key": "YOUR_COSYVOICE_API_KEY_HERE",
    "port": 3333,
    "https_enabled": true,
    "https_key_path": "certs/servers.local.key.pem",
    "https_cert_path": "certs/servers.local.cert.pem"
  },

  "weather_service": {
    "amap_api_key": "YOUR_AMAP_API_KEY_HERE",
    "port": 3001
  },

  "iot_cloud_platform": {
    "mysql": {
      "root_password": "CHANGE_ME_STRONG_PASSWORD",
      "database": "iot_cloud",
      "user": "iot_user",
      "password": "CHANGE_ME_STRONG_PASSWORD",
      "port": 3306
    },
    "redis": {
      "port": 6379,
      "password": ""
    },
    "emqx": {
      "dashboard_username": "admin",
      "dashboard_password": "CHANGE_ME_STRONG_PASSWORD",
      "mqtt_app_username": "iot_core",
      "mqtt_app_password": "CHANGE_ME_STRONG_PASSWORD",
      "mqtt_port": 1883,
      "mqtt_ssl_port": 8883,
      "websocket_port": 8083,
      "dashboard_port": 18083
    },
    "backend": {
      "jwt_secret": "CHANGE_ME_TO_RANDOM_64_CHAR_STRING_FOR_JWT_SIGNING",
      "port": 8080
    },
    "admin": {
      "username": "admin",
      "password": "CHANGE_ME_STRONG_PASSWORD",
      "email": "admin@example.com"
    },
    "grafana": {
      "admin_user": "admin",
      "admin_password": "CHANGE_ME_STRONG_PASSWORD",
      "port": 3000
    }
  },

  "security_notes": {
    "warning": "IMPORTANT: Replace ALL placeholder values before use!",
    "recommendations": [
      "Copy this file to credentials.json and fill in real values",
      "Never commit credentials.json to version control",
      "Change all default passwords before production deployment",
      "Use strong, randomly generated passwords (minimum 16 characters)",
      "Rotate API keys regularly (at least every 90 days)",
      "Enable HTTPS/TLS for all services in production",
      "Revoke exposed credentials immediately if leaked",
      "Use different passwords for each service",
      "Consider using a password manager to generate strong passwords"
    ],
    "api_key_sources": {
      "deepseek": "https://platform.deepseek.com/",
      "cosyvoice": "https://bailian.console.aliyun.com/?tab=model#/api-key",
      "amap": "https://lbs.amap.com/"
    }
  }
