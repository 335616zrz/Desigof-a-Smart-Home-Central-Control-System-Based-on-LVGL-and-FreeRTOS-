# DeepSeek API密钥 - 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 服务端口
PORT=3333

# TTS配置（CosyVoice云端服务）
TTS_ENABLED=false
TTS_PROVIDER=local
TTS_FALLBACK_PROVIDER=none
# （可选）TTS 文本清洗：去掉“（微笑点头）”这类舞台动作，不读出来
TTS_STRIP_STAGE_DIRECTIONS=true
# DashScope API Key（CosyVoice 同一套 Key，二选一配置即可）
DASHSCOPE_API_KEY=
COSYVOICE_API_KEY=your_cosyvoice_api_key_here
COSYVOICE_MODEL=cosyvoice-v3-plus
COSYVOICE_VOICE=longhuhu_v3
# 预置音色示例：龙安欢（欢脱元气女） -> longanhuan
# COSYVOICE_VOICE=longanhuan
COSYVOICE_FORMAT=pcm
COSYVOICE_SAMPLE_RATE=24000
COSYVOICE_ENABLE_SSML=false
COSYVOICE_WORD_TIMESTAMPS=false
# Instruct（情感/场景/角色提示）：注意末尾一定要有中文句号“。”
# COSYVOICE_INSTRUCTION=你正在进行闲聊对话，你说话的情感是happy。
COSYVOICE_INSTRUCTION=

# （可选）CosyVoice PCM 节流/匀速发送（避免设备端队列被突发打爆导致丢音）
# - chunkMs: 建议 20–40ms
# - prebufferMs: 建议 80–200ms（越大越稳但延迟越高）
COSYVOICE_PACE_ENABLED=true
COSYVOICE_PACE_CHUNK_MS=40
COSYVOICE_PACE_PREBUFFER_MS=120
COSYVOICE_PACE_MAX_BUFFER_MS=60000

# （可选）管理员密钥：用于保护 /api/cosyvoice/* 声音复刻管理接口
# 请求时携带 Header：x-api-key: $ADMIN_API_KEY
ADMIN_API_KEY=

# HTTPS/WSS设置
HTTPS_ENABLED=true
HTTPS_KEY=certs/servers.local.key.pem
HTTPS_CERT=certs/servers.local.cert.pem

# ASR 设置（低延时推荐：流式 partial + SenseVoice final）
ASR_WORKER_SCRIPT=scripts/asr_worker_hybrid.py

# 流式模型（低延时 partial）
ASR_STREAMING_MODEL=paraformer-zh-streaming
ASR_STREAMING_MODEL_REVISION=v2.0.4
ASR_STREAMING_DEVICE=cpu

# SenseVoice（高准确 final）
SENSEVOICE_MODEL=iic/SenseVoiceSmall
SENSEVOICE_VAD_MODEL=fsmn-vad
SENSEVOICE_PUNC_MODEL=
SENSEVOICE_DEVICE=cpu
SENSEVOICE_USE_ITN=true
SENSEVOICE_MERGE_VAD=true
ENABLE_STREAMING_PARTIAL=true
ENABLE_SENSEVOICE_FINAL=true

# 服务端降噪（noisereduce）
ENABLE_NOISEREDUCE=true
NOISEREDUCE_PROP_DECREASE=0.7

# （可选）纯句级 final（不出 partial）：使用 SenseVoice worker：
# ASR_WORKER_SCRIPT=scripts/sensevoice_worker.py
#
# （可选）纯流式 partial/final（不跑 SenseVoice）：使用 Paraformer 流式 worker：
# ASR_WORKER_SCRIPT=scripts/asr_worker_streaming.py
# ASR_STREAMING_MODEL=paraformer-zh-streaming
# ASR_STREAMING_MODEL_REVISION=v2.0.4
# ASR_STREAMING_DEVICE=cpu

# PORT=3000
