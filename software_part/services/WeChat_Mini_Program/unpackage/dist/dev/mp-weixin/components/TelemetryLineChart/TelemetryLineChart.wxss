:host{display:flex;flex-direction:column}
.chart-card{background:var(--w-card-bg);border-radius:14px;padding:12px;margin-bottom:12px}.header{display:flex;flex-direction:row;align-items:center;justify-content:space-between;margin-bottom:10px}.title{font-weight:600;color:var(--w-text-primary)}.latest{display:flex;flex-direction:row;align-items:baseline;gap:2px}.value{font-size:16px;font-weight:700;color:var(--w-primary)}.chart-card.humidity .value{color:#00c853}.unit{font-size:12px;color:var(--w-text-secondary)}.chart-wrap{width:100%;height:240px;overflow:visible}.ec-host{width:100%;height:100%;overflow:visible}.empty{width:100%;height:240px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:12px;gap:6px}.empty-text{color:var(--w-text-secondary)}
