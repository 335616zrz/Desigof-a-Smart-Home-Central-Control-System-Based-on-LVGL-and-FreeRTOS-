.card {
  background: var(--w-card-bg);
  border-radius: 14px;
  padding: 12px;
}
.header {
  margin-bottom: 10px;
}
.title {
  font-weight: 600;
  color: var(--w-text-primary);
}
.empty {
  color: var(--w-text-secondary);
  font-size: 12px;
  padding: 10px 0;
}
.item {
  display: flex;
  flex-direction: row;
  gap: 10px;
  padding: 10px 0;
  border-top: 1px solid var(--w-border);
  cursor: pointer;
}
.item:active {
  background: var(--w-bg);
}
.item:first-child {
  border-top: 0;
  padding-top: 0;
}
.dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-top: 4px;
  background: #9ca3af;
}
.dot.critical {
  background: var(--w-danger);
}
.dot.warning {
  background: var(--w-warning);
}
.dot.info {
  background: var(--w-primary);
}
.content {
  flex: 1;
}
.msg {
  font-weight: 600;
  color: var(--w-text-primary);
  font-size: 13px;
}
.meta {
  margin-top: 4px;
  color: var(--w-text-secondary);
  font-size: 12px;
}
.sep {
  margin: 0 6px;
}