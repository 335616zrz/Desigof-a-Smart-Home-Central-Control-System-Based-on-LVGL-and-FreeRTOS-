:host{display:flex;flex-direction:column}
.card{background:var(--w-card-bg);border-radius:14px;padding:12px}.header{margin-bottom:10px}.title{font-weight:600;color:var(--w-text-primary)}.table{border:1px solid var(--w-border);border-radius:12px;overflow:hidden}.tr{display:flex;flex-direction:row;align-items:center;padding:10px 8px;border-top:1px solid var(--w-border)}.tr:first-child{border-top:0}.th{background:var(--w-bg)}.td{font-size:12px;color:var(--w-text-primary)}.device{flex:1.4}.num{flex:1;text-align:right}.empty{padding:12px;color:var(--w-text-secondary);font-size:12px}
