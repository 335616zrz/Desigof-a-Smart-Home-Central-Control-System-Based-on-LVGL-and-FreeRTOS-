:host{display:flex;flex-direction:column}
.badge{display:inline-flex;flex-direction:row;align-items:center;gap:4px;padding:2px 8px;border-radius:999px;font-size:12px;line-height:18px}.sep{opacity:.7}.critical{background:#fff1f0;color:#cf1322}.warning{background:#fff7e6;color:#ad6800}.info{background:#e6f7ff;color:#096dd9}.default{background:#f2f3f5;color:#666}
