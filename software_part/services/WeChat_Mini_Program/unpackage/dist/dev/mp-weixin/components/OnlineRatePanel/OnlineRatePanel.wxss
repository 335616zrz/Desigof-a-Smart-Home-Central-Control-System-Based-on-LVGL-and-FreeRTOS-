:host{display:flex;flex-direction:column}
.panel{background:var(--w-card-bg);border-radius:14px;padding:14px;display:flex;flex-direction:column;align-items:center;justify-content:center}.circle-wrap{position:relative;width:100px;height:100px}.circle-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);text-align:center}.percent{font-size:18px;font-weight:700;color:var(--w-text-primary)}.label{margin-top:2px;font-size:12px;color:var(--w-text-secondary)}.desc{margin-top:10px;font-size:12px;color:var(--w-text-secondary)}
