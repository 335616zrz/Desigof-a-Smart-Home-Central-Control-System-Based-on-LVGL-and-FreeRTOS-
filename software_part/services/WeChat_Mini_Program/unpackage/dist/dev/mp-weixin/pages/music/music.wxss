@import "../../uvue.wxss";
:host{display:flex;flex-direction:column}
.page{min-height:100vh;padding:12px;background:#f7f8fa}.header{display:flex;flex-direction:column;gap:10px;margin-bottom:12px}.header-actions{display:flex;flex-direction:row;gap:8px;justify-content:flex-end}.player{background:#fff;border-radius:12px;padding:12px;margin-bottom:12px}.player-title{font-weight:600}.player-name{margin-top:6px;color:#111;font-size:14px}.player-actions{margin-top:10px;display:flex;flex-direction:row;align-items:center;gap:10px}.player-time{color:#666;font-size:12px}.item{background:#fff;border-radius:12px;padding:12px;margin-bottom:10px}.row{display:flex;flex-direction:row;justify-content:space-between;align-items:flex-start;gap:10px}.name{font-weight:600;flex:1;word-break:break-all}.row-actions{display:flex;flex-direction:row;gap:8px;flex-shrink:0;flex-wrap:wrap;justify-content:flex-end}.meta{margin-top:6px;color:#666;font-size:12px;word-break:break-all}.modal-body{padding:6px 0}
