.page {
  min-height: 100vh;
  padding: 12px;
  background: var(--w-bg);
}
.hero {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 12px;
}
.stats-grid {
  margin-bottom: 12px;
}
.card {
  background: var(--w-card-bg);
  border-radius: 14px;
  padding: 12px;
  margin-bottom: 12px;
  transition: transform 120ms ease, box-shadow 120ms ease;
}
.card:active {
  transform: scale(0.99);
}
.section-head {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.section-title {
  font-weight: 600;
  color: var(--w-text-primary);
}
.spacer {
  height: 12px;
}
.actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8px;
}
.data-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}
@media (min-width: 768px) {
.hero {
    flex-direction: row;
    align-items: stretch;
}
.data-grid {
    flex-direction: row;
}
}