@import "../../uvue.wxss";
:host{display:flex;flex-direction:column}
page{height:auto}.page{min-height:100vh;padding:12px;background:var(--w-bg);overflow:visible}.hero{display:flex;flex-direction:column;gap:12px;margin-bottom:12px}.stats-grid{margin-bottom:12px}.card{background:var(--w-card-bg);border-radius:14px;padding:12px;margin-bottom:12px;transition:box-shadow .12s ease}.section-head{display:flex;flex-direction:column;gap:10px}.section-title{font-weight:600;color:var(--w-text-primary)}.charts-section{width:100%;overflow:visible}.data-grid{display:flex;flex-direction:column;gap:12px;margin-top:12px;width:100%;overflow:visible}.quick-fab{position:fixed;right:16px;bottom:24px;width:52px;height:52px;border-radius:26px;background:var(--w-primary);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 20px rgba(0,0,0,.18);z-index:9999}.quick-fab:active{transform:scale(.96)}.quick-fab__text{color:#fff;font-size:12px;font-weight:700}.quick-drawer{width:260px;height:100%;background:var(--w-card-bg);padding:16px 14px;box-sizing:border-box;display:flex;flex-direction:column;gap:12px}.quick-title{font-weight:700;color:var(--w-text-primary)}.quick-actions{display:flex;flex-direction:column;gap:10px}@media (min-width: 768px){.hero{flex-direction:row;align-items:stretch}.data-grid{flex-direction:row}}
