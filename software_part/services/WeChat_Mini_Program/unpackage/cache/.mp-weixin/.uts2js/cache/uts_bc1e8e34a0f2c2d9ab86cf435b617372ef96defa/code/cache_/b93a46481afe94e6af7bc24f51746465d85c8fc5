.empty.news\"),\n                message: t(\"up.empty.message\"),\n                list: t(\"up.empty.list\"),\n                data: t(\"up.empty.data\"),\n                comment: t(\"up.empty.comment\"),\n            })\n        };\n    },\n    computed: {\n        // 组件样式\n        emptyStyle() {\n            const style = new UTSJSONObject({});\n            style.marginTop = addUnit(this.marginTop);\n            // 合并customStyle样式，此参数通过mixin中的props传递\n            return deepMerge(addStyle(this.customStyle), style);\n        },\n        // 文本样式\n        textStyle() {\n            const style = new UTSJSONObject({});\n            style.color = this.textColor;\n            style.fontSize = addUnit(this.textSize);\n            return style;\n        },\n        // 判断icon是否图片路径\n        isSrc() {\n            return this.icon.indexOf('/') >= 0;\n        }\n    },\n    methods: {\n        addUnit\n    }\n});\n//# sourceMappingURL=E:/HBuilderProjects/%E5%9F%BA%E4%BA%8ELVGL%E4%B8%8EFree%20RTOS%E7%9A%84%E6%99%BA%E8%83%BD%E4%B8%AD%E6%8E%A7%E7%B3%BB%E7%BB%9F%E8%AE%BE%E8%AE%A1_%E5%BE%AE%E4%BF%A1%E5%B0%8F%E7%A8%8B%E5%BA%8F/uni_modules/uview-plus/components/u-empty/u-empty.vue?vue&type=script&lang.uts.js.map","references":["E:/HBuilderProjects/基于LVGL与Free RTOS的智能中控系统设计_微信小程序/uni_modules/uview-plus/components/u-empty/props.js","E:/HBuilderProjects/基于LVGL与Free RTOS的智能中控系统设计_微信小程序/uni_modules/uview-plus/libs/mixin/mpMixin.js","E:/HBuilderProjects/基于LVGL与Free RTOS的智能中控系统设计_微信小程序/uni_modules/uview-plus/libs/mixin/mixin.js","E:/HBuilderProjects/基于LVGL与Free RTOS的智能中控系统设计_微信小程序/uni_modules/uview-plus/libs/function/index.js","E:/HBuilderProjects/基于LVGL与Free RTOS的智能中控系统设计_微信小程序/uni_modules/uview-plus/libs/i18n/index.js"],"uniExtApis":[],"map":"{\"version\":3,\"file\":\"u-empty.vue?vue&type=script&lang.uts.js\",\"sourceRoot\":\"\",\"sources\":[\"u-empty.vue?vue&type=script&lang.uts\"],\"names\":[],\"mappings\":\";AACC,OAAO,EAAE,KAAK,EAAE,MAAM,SAAS,CAAC;AAChC,OAAO,EAAE,OAAO,EAAE,MAAM,0B