		font-size: 18px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.desc {
		font-size: 13px;
		color: #666;
		margin-bottom: 16px;
		line-height: 1.5;
	}

	.form-item {
		margin-bottom: 16px;
	}

	.label {
		display: block;
		font-size: 14px;
		font-weight: 500;
		color: #333;
		margin-bottom: 8px;
	}

	.hint {
		display: block;
		font-size: 12px;
		color: #999;
		margin-top: 4px;
	}

	.current {
		background: #f5f7fa;
		border-radius: 8px;
		padding: 10px 12px;
		margin-bottom: 16px;
	}

	.current .label {
		font-size: 12px;
		color: #666;
		margin-bottom: 4px;
	}

	.current .value {
		font-size: 14px;
		color: #333;
		word-break: break-all;
	}

	.actions {
		display: flex;
		flex-direction: row;
		gap: 10px;
		margin-top: 12px;
	}

	.tips {
		margin-top: 20px;
		padding: 12px;
		background: #fef6e6;
		border-radius: 8px;
	}

	.tips-title {
		display: block;
		font-size: 13px;
		font-weight: 500;
		color: #e6a23c;
		margin-bottom: 8px;
	}

	.tips-item {
		display: block;
		font-size: 12px;
		color: #909399;
		line-height: 1.8;
	}

	.kv {
		margin-bottom: 10px;
	}

	.k {
		display: block;
		color: #666;
		font-size: 12px;
	}

	.v {
		display: block;
		margin-top: 4px;
		color: #111;
		font-size: 14px;
	}
</style>
