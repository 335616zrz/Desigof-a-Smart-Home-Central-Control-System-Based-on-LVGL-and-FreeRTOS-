# ========================================
# IoT Cloud Platform 环境变量配置模板
# ========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写所有 YOUR_XXX_HERE 占位符
# 3. 确保 .env 不要提交到 Git

# ========================================
# MySQL 数据库配置
# ========================================
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD_HERE
MYSQL_DATABASE=iot_cloud
MYSQL_USER=YOUR_MYSQL_USER_HERE
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
MYSQL_PORT=3306

# ========================================
# Redis 配置
# ========================================
REDIS_PORT=6379
# REDIS_PASSWORD=  # 可选：设置Redis密码以增强安全性

# ========================================
# EMQX MQTT Broker 配置
# ========================================
EMQX_DASHBOARD_USERNAME=YOUR_EMQX_ADMIN_USERNAME_HERE
EMQX_DASHBOARD_PASSWORD=YOUR_EMQX_ADMIN_PASSWORD_HERE
EMQX_MQTT_USERNAME=YOUR_MQTT_APP_USERNAME_HERE
EMQX_MQTT_PASSWORD=YOUR_MQTT_APP_PASSWORD_HERE
EMQX_MQTT_PORT=1883
EMQX_MQTT_SSL_PORT=8883
EMQX_WEBSOCKET_PORT=8083
EMQX_DASHBOARD_PORT=18083

# ========================================
# Spring Boot Backend 配置
# ========================================
BACKEND_PORT=8080
JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET_HERE_AT_LEAST_64_CHARS
SPRING_PROFILES_ACTIVE=docker

# ========================================
# Backend 管理员初始化（必填）
# ========================================
# 首次启动会创建/更新该管理员账号（ROLE_PRIMARY_ADMIN）。
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
APP_ADMIN_EMAIL=admin@example.com

# ========================================
# Grafana 配置
# ========================================
GRAFANA_ADMIN_USER=YOUR_GRAFANA_ADMIN_USERNAME_HERE
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_ADMIN_PASSWORD_HERE
GRAFANA_PORT=3000

# ========================================
# Frontend Gateway 配置
# ========================================
GATEWAY_PORT=8088

# ========================================
# 安全建议
# ========================================
# - 所有密码长度应至少 12 个字符
# - 使用大小写字母、数字和特殊字符的组合
# - JWT_SECRET 应该是随机生成的至少 64 个字符的字符串
# - 生产环境请启用 HTTPS/TLS 并使用更强的密码
